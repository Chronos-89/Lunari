require "godot"

type ItemCounts = Hash<String, Integer>

class ReplacementInventory
  @counts: ItemCounts = { "Potion" => 2, "Ether" => 1 }

  def count(name: String): Integer
    return @counts.fetch(name, 0)
  end

  def add(name: String, amount: Integer): Integer
    current: Integer = count(name)
    @counts[name] = current + amount
    return @counts.fetch(name, 0)
  end

  def label: String
    return "Potion x" + count("Potion").to_s
  end
end
