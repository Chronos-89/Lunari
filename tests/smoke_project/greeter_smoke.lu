require "godot"

type UserName = String
type GreetingText = String

class Greeter
  enum GreetingStyle { Normal, Loud = 2 }

  const DefaultPunctuation: String = "!"
  static @created: Integer = 0

  @name: UserName
  @punctuation: String = DefaultPunctuation

  attr_reader :name

  def initialize(name: UserName): void
    @name = name.capitalize
    Greeter.@created = Greeter.@created + 1
  end

  def salute: GreetingText
    return "Hello " + @name + @punctuation
  end
end

class LoudGreeter < Greeter
  def initialize(name: UserName): void
    super(name)
  end

  def salute: GreetingText
    return super.to_upper
  end
end

class Main :: Node
  signal greeted(message: String)

  @label: Label
  @icon: Resource
  @parent_node: Node

  @export @message: String = ""
  @seen_greeting: Boolean = false
  @count: Integer = 0
  @words: Array<String> = ["Hello", " ", "World"]

  def ready: void
    greeter: Greeter = LoudGreeter.new("world")

    @icon = load("res://icon.svg")
    @parent_node = self.get_parent()
    self.name = "LunariMain"
    self.greeted.connect(self.on_greeted)

    @label = Label.new
    @label.set_position(Vector2(4, 8))

    for word in @words
      @message = @message + word
    end

    match @message
      "Hello World":
        @message = greeter.salute
      else:
        @message = "Greeting failed"
    end

    if @label is Label
      typed_label: Label = @label as Label
      typed_label.text = @message
    end

    while @count < 2
      @count = @count + 1
    end

    @label.text = @message if @count == 2
    emit_signal("greeted", @message)
    add_child(@label)
  end

  def process(delta: Float): void
    @count = @count + 1
  end

  def on_greeted(message: String): void
    @seen_greeting = true
  end
end
