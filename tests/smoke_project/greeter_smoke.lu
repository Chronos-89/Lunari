require "godot"
require_relative "shared_greeter"

type UserName = String
type GreetingText = String
type MaybeGreeting = String | nil

module NameFormatter
  def format_name(name: UserName): UserName
    return name.capitalize
  end
end

class Greeter
  include NameFormatter

  @name: UserName
  @punctuation: String = "!"

  attr_reader :name
  attr_accessor :punctuation

  def initialize(name: UserName, punctuation: String = "!"): void
    @name = format_name(name)
    @punctuation = punctuation
  end

  def salute: GreetingText
    return "Hello " + @name + @punctuation
  end

  def maybe_salute(enabled: Boolean): MaybeGreeting
    if !enabled
      return nil
    end
    return salute
  end
end

class LoudGreeter < Greeter
  def initialize(name: UserName): void
    super(name, "!")
  end

  def salute: GreetingText
    return super.upcase
  end
end

class Main < Node
  @label: Label
  @message: GreetingText = ""
  @seen_process: Boolean = false
  @words: Array<String> = ["Hello", " ", "World"]

  def ready: void
    greeter: Greeter = LoudGreeter.new("world")
    shared: SharedGreeter = SharedGreeter.new("moon")

    @message = ""
    for word in @words
      @message = @message + word
    end

    match @message
      "Hello World":
        @message = greeter.salute
      else:
        @message = shared.salute
    end

    @label = Label.new
    @label.text = @message
    add_child(@label)
  end

  def process(delta: Float): void
    if delta >= 0.0
      @seen_process = true
    end
  end
end
