; Engine configuration file.
; It's best edited using the editor UI and not directly.

config_version=5

[application]

config/name="Lunari HD-2D Traveler"
config/description="Perspective 2D demo with paired Lunari and GDScript movement controllers, depth scaling, y-sort staging, and 2D lighting."
config/tags=PackedStringArray("2d", "demo", "lunari", "lighting", "hd-2d")
run/main_scene="res://world_lunari.tscn"
config/features=PackedStringArray("4.6")

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

